# Your WhatsApp admin number, INCLUDING country code, no + or spaces
# (e.g. 91XXXXXXXXXX for India, 1XXXXXXXXXX for US/Canada)
BOT_PHONE_NUMBER=91XXXXXXXXXX
LOG_LEVEL=info

# How often (in minutes) the bot prints a "still alive" heartbeat line with
# activity counters. Set to 0 to disable.
STATUS_HEARTBEAT_MINUTES=30
