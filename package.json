{
  "name": "whatsapp-spam-guard",
  "version": "1.0.0",
  "description": "Auto-moderation bot for a WhatsApp Community: detects spam via configurable rules (investment scams, job scams, etc.), deletes it for everyone, and removes the sender from all community groups.",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/index.js",
    "setup": "node --disable-warning=ExperimentalWarning scripts/setup.js",
    "list-groups": "node --disable-warning=ExperimentalWarning scripts/list-groups.js",
    "test-message": "node scripts/test-message.js",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.9",
    "dotenv": "^16.4.5",
    "pino": "^9.4.0",
    "pino-pretty": "^13.1.3",
    "prompts": "^2.4.2",
    "qrcode-terminal": "^0.12.0"
  }
}
